rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verified() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return verified() && request.auth.token.email in [
        "zain@gdgtulsa.com",
        "zainkhan1994.zk@gmail.com"
      ];
    }

    match /members/{uid} {
      allow create: if verified()
        && request.auth.uid == uid
        && request.resource.data.email == request.auth.token.email;
      allow read, update: if isAdmin() || (verified() && request.auth.uid == uid);
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }

    match /memberResources/{resourceId} {
      allow read: if verified();
      allow create, update, delete: if isAdmin();
    }

    match /memberEvents/{eventId} {
      allow read: if verified();
      allow create, update, delete: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow create: if verified()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow read: if isAdmin() || (verified() && resource.data.uid == request.auth.uid);
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /scheduleRequests/{requestId} {
      allow create: if verified()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow read: if isAdmin() || (verified() && resource.data.uid == request.auth.uid);
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
